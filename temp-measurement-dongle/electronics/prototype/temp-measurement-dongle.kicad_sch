	(text "miso - Also known as q, this is the input of the serial stream into the ESP32\nmosi - Also known as d, this is the output of the serial stream from the ESP32\nsclk - Clock signal. Each data bit is clocked out or in on the positive or negative edge of this signal\nquadwp - Write Protect signal. Only used for 4-bit (qio/qout) transactions.\nquadhd - Hold signal. Only used for 4-bit (qio/qout) transactions."
		(exclude_from_sim no)
		(at 16.002 172.72 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "3c443516-0081-4d66-a48e-b12c1e3b16e6")
	)
	(text "ESP32-S3-WROOM-1"
		(exclude_from_sim no)
		(at 15.494 157.988 0)
		(effects
			(font
				(size 3.048 3.048)
				(thickness 0.6096)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "4e27a9a6-ca54-4b24-ae88-1c2450a37552")
	)
	(text "Program the Fast Charge Current (ISET):\nRISET = KISET / ICHG\nKISET = 890 AΩ from the electrical characteristics table.\nRISET = 890 AΩ / 0.8 A = 1.1125 kΩ -> 1.13 kΩ"
		(exclude_from_sim no)
		(at 232.156 76.962 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "6003a008-d236-44f9-af7c-6e50b72a3de9")
	)
	(text "DPPM"
		(exclude_from_sim no)
		(at 178.054 23.876 0)
		(effects
			(font
				(size 3.81 3.81)
				(thickness 0.762)
				(bold yes)
				(italic yes)
			)
			(justify left top)
		)
		(uuid "86e02d5d-6e3f-4e09-831f-e746ad35a477")
	)
	(text "3 Wire to Force+ \n2/4 Wire to GND\nConnect 2_Wire if use 2/4 Wire"
		(exclude_from_sim no)
		(at 262.382 138.938 0)
		(effects
			(font
