            //     icon: action.icon;
            //     text: action.name;
            //     isActive: last_key == idx + 1;
            //     clicked => {
            //         root.current-subpage = idx + 1;
            //     }
            // }
        }

        Text {
            wrap: TextWrap.word-wrap;
            text: "Es ist Samstagmorgen. Die Sonne scheint über Berlin. Lukas geht zum berrufschule.";
            font-size: 13px;
            font-weight: 1000;
        }
    }
}
