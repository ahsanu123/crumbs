	(text "Program Fast-Charge Safety Timer (TMR):\nRTMR = tMAXCHG / (10 × KTMR )\nKTMR = 48 s/kΩ from the electrical characteristics table.\nRTMR = (6.25 hr × 3600 s/hr) / (10 × 48 s/kΩ) = 46.8 kΩ ->  46.4 kΩ\n"
		(exclude_from_sim no)
		(at 248.92 169.926 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "67243905-7cf9-4b64-ae6f-02358ac2f0c9")
	)
	(text "ESP32-S3-WROOM-1"
		(exclude_from_sim no)
		(at 151.13 94.742 0)
		(effects
			(font
				(size 3.048 3.048)
				(thickness 0.6096)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "956b7048-da54-4caf-a9c4-ac1fac6c23e0")
	)
	(text "miso - Also known as q, this is the input of the serial stream into the ESP32\nmosi - Also known as d, this is the output of the serial stream from the ESP32\nsclk - Clock signal. Each data bit is clocked out or in on the positive or negative edge of this signal\nquadwp - Write Protect signal. Only used for 4-bit (qio/qout) transactions.\nquadhd - Hold signal. Only used for 4-bit (qio/qout) transactions."
		(exclude_from_sim no)
		(at 151.638 105.156 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "b1ead5a8-5c41-4852-9b84-fda1b146b83c")
	)
